# Сервер
PORT=8080
BACKEND_PORT=8080
FRONTEND_PORT=5173

# PostgreSQL — используются и приложением, и docker-compose.yml
# При запуске через Docker DB_HOST переопределяется на postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=publishier
DB_PASSWORD=change-me-to-a-strong-password
DB_NAME=publishier
DB_SSLMODE=disable

# PostgreSQL (вариант 2 — одна строка, если задана — переменные выше игнорируются приложением)
# DB_DSN=host=localhost port=5432 user=publishier password=change-me dbname=publishier sslmode=disable

# JWT (любая длинная случайная строка)
JWT_SECRET=change-me-to-a-long-random-string

# AES-ключ для шифрования bot-токенов Telegram.
# Должен быть ровно 16, 24 или 32 символа (байта).
AES_SECRET=1234567890123456

# Опционально
# TELEGRAM_BASE_URL=https://api.telegram.org
